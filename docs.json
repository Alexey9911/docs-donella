{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Bookie",
  "logo": {
    "light": "/logo/dark.svg",
    "dark": "/logo/light.svg"
  },
  "favicon": "/favicon.svg",
  "colors": {
    "primary": "#f97316",
    "light": "#fb923c",
    "dark": "#ea580c"
  },
  "appearance": {
    "default": "light"
  },
  "navigation": {
    "global": {
      "anchors": [
        {
          "anchor": "GitHub",
          "icon": "github",
          "href": "https://github.com/Bookiepmndrs/bookie-repo"
        },
        {
          "anchor": "Twitter",
          "icon": "x-twitter",
          "href": "https://x.com/bookiedfi_bot"
        },
        {
          "anchor": "Telegram",
          "icon": "telegram",
          "href": "https://t.me/bookiedfi_bot"
        }
      ]
    },
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "GETTING STARTED",
            "icon": "bolt",
            "pages": [
              "index",
              "introduction/quickstart",
              "introduction/architecture"
            ]
          },
          {
            "group": "CORE FEATURES",
            "icon": "brain",
            "pages": [
              "core-features/natural-language",
              "core-features/jupiter-integration",
              "core-features/portfolio-tracking",
              "core-features/transaction-speed"
            ]
          },
          {
            "group": "SECURITY",
            "icon": "shield",
            "pages": [
              "integrations/solana",
              "integrations/wallet-security",
              "integrations/transaction-simulation"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "groups": [
          {
            "group": "Introduction",
            "icon": "book",
            "pages": [
              "api-reference/introduction",
              "api-reference/authentication"
            ]
          },
          {
            "group": "Intent Operations",
            "icon": "brain",
            "pages": [
              "api-reference/sessions/create-session",
              "api-reference/sessions/delete-session"
            ]
          },
          {
            "group": "Portfolio & Prices",
            "icon": "wallet",
            "pages": [
              "api-reference/sessions/get-session",
              "api-reference/messages/send-message"
            ]
          },
          {
            "group": "Transaction History",
            "icon": "clock-rotate-left",
            "pages": [
              "api-reference/messages/get-history"
            ]
          },
          {
            "group": "Analytics",
            "icon": "chart-line",
            "pages": [
              "api-reference/analytics/get-metrics",
              "api-reference/analytics/get-usage"
            ]
          }
        ]
      }
    ]
  },
  "navbar": {
    "primary": {
      "type": "button",
      "label": "Try Bookie",
      "href": "https://bookiebot.dev"
    }
  },
  "footer": {
    "socials": {
      "x": "https://x.com/bookiedfi_bot",
      "github": "https://github.com/Bookiepmndrs/bookie-repo",
      "telegram": "https://t.me/bookiedfi_bot",
      "website": "https://bookiebot.dev"
    }
  }
}
